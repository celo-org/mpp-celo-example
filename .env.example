# Copy to .env and fill in.  cp .env.example .env && chmod 600 .env

# Network: testnet = Celo Sepolia (default), mainnet = Celo.
MPP_NETWORK=testnet

# ── Seller ───────────────────────────────────────────────────────────────────
# MPP server secret — signs/verifies challenges & receipts. >= 32 bytes.
#   Generate:  openssl rand -base64 32
MPP_SECRET_KEY=

# Facilitator API key (settlement credits). Get one at https://x402.celo.org
# (connect wallet → Create API key). New accounts start with free credits.
X402_API_KEY=

# The wallet that RECEIVES the USDC payments (your own address).
SELLER_PAY_TO=

# ── Buyer ────────────────────────────────────────────────────────────────────
# A throwaway wallet funded with a little Celo Sepolia USDC.
#   Generate:  cast wallet new    (or any EVM key)
#   Fund USDC: https://faucet.circle.com  (select Celo Sepolia)
# The buyer needs NO native CELO — the facilitator sponsors settlement gas.
# NEVER put a wallet with real funds here. NEVER commit .env.
BUYER_PRIVATE_KEY=
